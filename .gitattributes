# Force LF for all text files; scripts must not have CRLF on Linux servers
* text=auto eol=lf

# Explicitly mark shell scripts and configs as LF
*.sh        text eol=lf
*.mjs       text eol=lf
*.py        text eol=lf
*.conf      text eol=lf
*.template  text eol=lf
*.j2        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.example   text eol=lf
.gitignore  text eol=lf
Makefile    text eol=lf

# Binary files; no conversion
*.png  binary
*.jpg  binary
*.ico  binary
