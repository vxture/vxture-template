# Environment - never commit real secrets
.env
*.env
.env.*
!.env.example
!.env.local.example
!deploy/env/*.env
.env.bak.*
.npmrc
# The .npmrc only declares the @vxture GitHub Packages registry and references
# ${NODE_AUTH_TOKEN} (no literal secret). It MUST stay committed so CI
# `pnpm install` can resolve @vxture/* packages. Ignored-then-negated to guard
# against a local `npm login` writing a literal token into it.
!.npmrc

# Runtime data and generated configs
data/
backup/
private/
runtime/
generated/

# TLS / certificates
*.pem
*.key
*.crt
*.csr
*.p12
*.pfx

# Logs
*.log
logs/

# Node / Next.js / pnpm
node_modules/
.pnpm-store/
.npm-cache/
.next/
out/
build/
dist/
*.tsbuildinfo
next-env.d.ts

# Test / coverage
coverage/
.nyc_output/

# OS / editor
.DS_Store
.vscode/
.idea/
*.swp
*.swo

.claude/

# Python bytecode (local compileall artifacts)
__pycache__/
*.pyc
